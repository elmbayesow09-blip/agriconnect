<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Agriculteurs - AgriConnect</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<style>
body{font-family:Arial;margin:0;background:#f4f4f4;}
header{background:#27ae60;color:white;padding:20px;text-align:center;font-size:28px;}
nav{background:#2c3e50;padding:10px;text-align:center;}
nav a{color:white;margin:15px;text-decoration:none;}
nav a:hover{color:#1abc9c;}
.section{text-align:center;padding:40px;}
.card{background:white;width:250px;display:inline-block;margin:20px;padding:20px;border-radius:10px;box-shadow:0 5px 15px rgba(0,0,0,0.2);}
.card img{width:100%;height:150px;object-fit:cover;border-radius:8px;}
#map{height:400px;margin:20px 0;border-radius:10px;}
button{background:#27ae60;color:white;border:none;padding:10px 15px;margin-top:10px;border-radius:5px;cursor:pointer;}
button:hover{background:#1e8449;}
</style>
</head>
<body>

<header>🌱 AgriConnect Sénégal</header>
<nav>
<a href="index.html">Accueil</a>
<a href="agriculteurs.html">Agriculteurs</a>
<a href="produits.html">Produits</a>
<a href="contact.html">Contact</a>
</nav>

<section class="section">
<h2>Nos Agriculteurs</h2>
<div id="map"></div>
<div id="agriculteurs-container"></div>
</section>

<script>
// Exemple d’agriculteurs (tu peux ajouter plus dans agriculteurs.json)
const container = document.getElementById("agriculteurs-container");
fetch("agriculteurs.json")
.then(res => res.json())
.then(data => {
  data.forEach(agri => {
    const card = document.createElement("div");
    card.className="card";
    card.innerHTML = `<img src="images/${agri.photo}"><h3>${agri.nom}</h3><p>${agri.description}</p>
      <a href="https://wa.me/221771234567" target="_blank">
      <button>WhatsApp</button></a>`;
    container.appendChild(card);
  });
});

// Carte Leaflet
var map = L.map('map').setView([14.4974, -14.4524], 6);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);
L.marker([14.7167,-17.4677]).addTo(map).bindPopup("Agriculteur à Dakar");
L.marker([16.0167,-16.5000]).addTo(map).bindPopup("Agriculteur à Saint-Louis");
</script>

<footer>AgriConnect © 2026</footer>
</body>
</html>
