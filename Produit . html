<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Produits</title>
<style>
body{font-family:Arial;margin:0;background:#f4f4f4;}
header{background:green;color:white;padding:20px;text-align:center;}
nav{background:#222;padding:10px;text-align:center;}
nav a{color:white;margin:15px;text-decoration:none;}
.section{text-align:center;padding:40px;}
.card{background:white;width:250px;display:inline-block;margin:20px;padding:20px;box-shadow:0 0 10px rgba(0,0,0,0.2);}
.card img{width:100%;height:150px;object-fit:cover;}
</style>
</head>

<body>

<header>🌱 AgriConnect Sénégal</header>

<nav>
<a href="index.html">Accueil</a>
<a href="agriculteurs.html">Agriculteurs</a>
<a href="produits.html">Produits</a>
<a href="contact.html">Contact</a>
</nav>

<section class="section">

<h2>Nos Produits</h2>

<div id="produits-container"></div>
<h3>Ajouter un produit</h3>

<input type="text" id="nomProduit" placeholder="Nom du produit">

<input type="text" id="imageProduit" placeholder="Nom de l'image (ex: tomates.jpg)">

<p>${produit.description}</p>

<a href="https://wa.me/221771234567" target="_blank">
<button>Contacter sur WhatsApp</button>
</a>

<br><br>

<button onclick="ajouterProduit()">Ajouter</button>

<script>

const container = document.getElementById("produits-container");

fetch("produits.json")
.then(response => response.json())
.then(data => {

data.forEach(produit => {

const card = document.createElement("div");
card.className="card";

card.innerHTML = `
<img src="${produit.image}">
<h3>${produit.nom}</h3>
<p>${produit.description}</p>
`;

container.appendChild(card);
function ajouterProduit(){

const nom = document.getElementById("nomProduit").value;
const image = document.getElementById("imageProduit").value;
const description = document.getElementById("descriptionProduit").value;

const container = document.getElementById("produits-container");

const card = document.createElement("div");
card.className = "card";

card.innerHTML = `
<img src="${image}">
<h3>${nom}</h3>
<p>${description}</p>
`;

container.appendChild(card);

}

});

});

</script>

</section>

</body>
</html>
